        </mxCell>
        <mxCell id="SCxPq8FJmXqeNOUXXJHq-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=14;" value="Why do we use API ?" vertex="1">
