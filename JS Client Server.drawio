        <mxCell id="ni-HQF6fzwf_cx5Zkhig-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font color=&quot;#0a0a0a&quot; face=&quot;Arial, Noto Sans Myanmar UI, sans-serif&quot; style=&quot;font-size: 14px;&quot;&gt;The JavaScript Fetch method is used for sending HTTP requests from client to server&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="658" x="59" y="41" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;color: rgb(0, 29, 53); font-family: Arial, &amp;quot;Noto Sans Myanmar UI&amp;quot;, sans-serif; font-size: 20px; font-weight: 600; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;1. Basic Syntax&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="160" x="85" y="84" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;fetch(&#39;https://jsonplaceholder.typicode.com/users&#39;)&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;  .then(res =&amp;gt; res.json())&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;  .then(data =&amp;gt; console.log(data))&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;.&lt;/span&gt;&lt;span class=&quot;mexSqb&quot; data-processed=&quot;true&quot; style=&quot;background-color: transparent; color: rgb(147, 52, 230);&quot;&gt;catch&lt;/span&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;(error =&amp;gt; console.error(&lt;/span&gt;&lt;span class=&quot;CS0cqb&quot; data-processed=&quot;true&quot; style=&quot;background-color: transparent; color: rgb(24, 128, 56);&quot;&gt;&#39;Error:&#39;&lt;/span&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;, error));&lt;/span&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="81" width="487" x="112" y="136" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 20px;&quot;&gt;&lt;font color=&quot;#001d35&quot; face=&quot;Arial, Noto Sans Myanmar UI, sans-serif&quot;&gt;&lt;b&gt;2. Modern Usage with Async/Await&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="352" x="84" y="400" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;async function load() {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; const res = await fetch(url);&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; const data = await res.json();&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; console.log(data);&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;}&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
