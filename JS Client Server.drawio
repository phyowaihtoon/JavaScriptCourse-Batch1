        <mxCell id="FzBO6bfzB8ek5okat1Op-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;" value="JSON" vertex="1">
