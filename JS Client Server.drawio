        <mxCell id="ni-HQF6fzwf_cx5Zkhig-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;color: rgb(0, 29, 53); font-family: Arial, &amp;quot;Noto Sans Myanmar UI&amp;quot;, sans-serif; font-size: 20px; font-weight: 600; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;1. Basic Syntax&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="160" x="85" y="84" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;fetch(&#39;https://jsonplaceholder.typicode.com/users&#39;)&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;  .then(res =&amp;gt; res.json())&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;  .then(data =&amp;gt; console.log(data))&lt;/font&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;.&lt;/span&gt;&lt;span class=&quot;mexSqb&quot; data-processed=&quot;true&quot; style=&quot;background-color: transparent; color: rgb(147, 52, 230);&quot;&gt;catch&lt;/span&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;(error =&amp;gt; console.error(&lt;/span&gt;&lt;span class=&quot;CS0cqb&quot; data-processed=&quot;true&quot; style=&quot;background-color: transparent; color: rgb(24, 128, 56);&quot;&gt;&#39;Error:&#39;&lt;/span&gt;&lt;span class=&quot;undefined&quot; data-processed=&quot;true&quot; style=&quot;color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); background-color: transparent;&quot;&gt;, error));&lt;/span&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="81" width="487" x="112" y="136" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 20px;&quot;&gt;&lt;font color=&quot;#001d35&quot; face=&quot;Arial, Noto Sans Myanmar UI, sans-serif&quot;&gt;&lt;b&gt;2. Modern Usage with Async/Await&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="352" x="84" y="400" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;async function load() {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; const res = await fetch(url);&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; const data = await res.json();&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; console.log(data);&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;}&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="92" width="487" x="111" y="433" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;fetch(url, {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; method: &#39;POST&#39;,&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; headers: {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; &#39;Content-Type&#39;: &#39;application/json&#39;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; },&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; body: JSON.stringify({ name: &#39;John&#39; })&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;});&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="137" width="487" x="112" y="244" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=13;" value="HTTP POST Request" vertex="1">
          <mxGeometry height="30" width="143" x="114" y="219" as="geometry" />
        </mxCell>
        <mxCell id="ni-HQF6fzwf_cx5Zkhig-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=13;" value="HTTP GET Request" vertex="1">
          <mxGeometry height="30" width="127" x="111" y="112" as="geometry" />
        </mxCell>
        <mxCell id="72u0uqD1D8jxeenJo_uA-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 20px;&quot;&gt;&lt;font color=&quot;#001d35&quot; face=&quot;Arial, Noto Sans Myanmar UI, sans-serif&quot;&gt;&lt;b&gt;3. Error Handling in Async/Await&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="352" x="84" y="569" as="geometry" />
        </mxCell>
        <mxCell id="72u0uqD1D8jxeenJo_uA-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fad7ac;strokeColor=#b46504;fontSize=14;" value="&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;div class=&quot;cm-line&quot;&gt;async function load() {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp; try {&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const res = await fetch(URL);&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const data= await res.json();&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; } catch (error) {&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;alert(&quot;Network connection is not available.&quot;);&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt; &lt;span class=&quot;ͼ6&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// ❌ This WON&#39;T catch 404 or 500&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div class=&quot;cm-line&quot;&gt;}&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="243" width="487" x="111" y="602" as="geometry" />
        </mxCell>
